# 鑒源 JianYuan — 環境變數範本(.env.example)
# 複製此檔為 .env.local(dev) / 在 Vercel Dashboard 設(production)
# v5.10.344 Sprint 6 收尾、補完所有新增 env vars

# ==================== 必設(production 不可空)====================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Python API(SSRF allowlist:必須是 jianyuan-* / fortune-reports-* / fortune-* 的 fly.dev)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic / OpenAI / Resend / 其他 secret key 略

# ==================== Cookie / Auth ====================

# v5.10.197 Codex P1 access_token httpOnly cookie 架構修
#   用於 sign /api/checkout/claim 設的 jy_report_claim cookie
#   必須是長隨機字串(32+ chars)、production env 必設
#   若未設、會 fallback 到 SUPABASE_JWT_SECRET(可運作但不建議)
#   生成命令:openssl rand -hex 32
REPORT_COOKIE_SECRET=replace-with-openssl-rand-hex-32

# Admin API key(timing-safe 比對、暴力鎖 5 次 30 分)
# 生成:openssl rand -hex 32
ADMIN_KEY=replace-with-openssl-rand-hex-32

# Vercel cron secret(v5.10.333 雙因子驗證 cron 真實性)
# Vercel cron 會自動帶 Authorization: Bearer $CRON_SECRET
# 生成:openssl rand -hex 32
CRON_SECRET=replace-with-openssl-rand-hex-32

# ==================== Sprint 5/6 監控 ====================

# Vercel Analytics + Speed Insights — 已 npm install、自動啟用、無需 env

# Sentry(error tracking、stub mode 若未設)
# 待 sentry.io 註冊 organization + project 後設置
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=xxx
# SENTRY_ORG=jianyuan-life
# SENTRY_PROJECT=web

# OpenTelemetry(distributed tracing、stub mode 若未設)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-collector

# ==================== Sprint 5/6 安全 ====================

# Cloudflare Turnstile CAPTCHA(防 bot 表單濫用、stub mode 若未設、production fail-CLOSED)
# 待 cloudflare.com 註冊 + 建 site key 後設置
# TURNSTILE_SECRET_KEY=0x4AAAAAAAxxx
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxx

# Vercel Edge Config(動態 IP/country blacklist、fail-OPEN 若未設)
# 步驟:Vercel Dashboard → Stores → Create Edge Config → attach to project
# attach 後 Vercel 自動注入 EDGE_CONFIG env(connection string)
# Items 結構:
#   key="blocked_ips" value=["1.2.3.4", "5.6.7.0/24"]
#   key="allowed_ips" value=["3.18.12.63", ...] # Stripe webhook IPs
#   key="blocked_countries" value=["KP", "IR"] # ISO-3166-1 alpha-2
# EDGE_CONFIG=https://edge-config.vercel.com/ecfg_xxx?token=xxx

# Upstash Redis(跨區 sliding window rate limit、in-memory fallback 若未設)
# 步驟:Vercel Dashboard → Storage → Marketplace → Upstash Redis → create
# 自動注入 KV_REST_API_URL + KV_REST_API_TOKEN
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# ==================== Tracking / Marketing ====================

# Google Analytics 4(consent mode v2、預設 denied、cookie banner 同意才升 granted)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel (Facebook Pixel、預設 revoked、marketing consent 才 grant)
# NEXT_PUBLIC_META_PIXEL_ID=xxxxxxxxxxxxxxxx

# ==================== 開發 / Debug ====================

# Vercel 自動注入(本地不要設):VERCEL_ENV / VERCEL_REGION / VERCEL_GIT_COMMIT_SHA
