{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "functions": {
    "app/api/admin/recalculate-report/route.ts": { "maxDuration": 800 },
    "app/api/generate-report/route.ts": { "maxDuration": 800 },
    "app/api/free-bazi/route.ts": { "maxDuration": 30 },
    "app/api/free-ziwei/route.ts": { "maxDuration": 30 },
    "app/api/free-qimen/route.ts": { "maxDuration": 30 },
    "app/api/free-purple/route.ts": { "maxDuration": 30 },
    "app/api/free-astro/route.ts": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/wp-admin", "destination": "/api/admin/honeypot?trap=wp-admin" },
    { "source": "/wp-login.php", "destination": "/api/admin/honeypot?trap=wp-login" },
    { "source": "/phpmyadmin", "destination": "/api/admin/honeypot?trap=phpmyadmin" },
    { "source": "/admin.php", "destination": "/api/admin/honeypot?trap=admin-php" },
    { "source": "/administrator", "destination": "/api/admin/honeypot?trap=administrator" },
    { "source": "/.env", "destination": "/api/admin/honeypot?trap=env" },
    { "source": "/.git/config", "destination": "/api/admin/honeypot?trap=git-config" }
  ],
  "redirects": [
    {
      "source": "/.well-known/change-password",
      "destination": "/auth/update-password",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/cron/retry-pending",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/keep-alive",
      "schedule": "*/4 * * * *"
    },
    {
      "path": "/api/cron/expire-points",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/feedback-reminder",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/followup-email",
      "schedule": "0 */1 * * *"
    },
    {
      "path": "/api/cron/check-stuck-reports",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/check-llm-balances",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/monthly-fixed-costs",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/monthly-pnl",
      "schedule": "0 1 1 * *"
    }
  ]
}
